# ═══════════════════════════════════════════════════════
# HH Job Ranker — переменные окружения
# ═══════════════════════════════════════════════════════
# Скопируйте этот файл в .env и заполните значения.
# Или запустите setup.sh — он сделает это интерактивно.
# ═══════════════════════════════════════════════════════

# --- AI провайдер ---
# Активный провайдер: openrouter или deepseek
AI_PROVIDER=openrouter

# OpenRouter (рекомендуется — много моделей, один ключ)
# Получить: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# DeepSeek (нативный API, дешевле)
# Получить: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- HH.ru API ---
# User-Agent для HH Public API (укажите свой email)
HH_USER_AGENT=HHJobRanker/1.0 (your@email.com)

# --- Приложение ---
# Порт веб-интерфейса
PORT=8000

# Интервал автоматического поиска (в часах)
SEARCH_INTERVAL_HOURS=2

# Количество параллельных AI-запросов при оценке
MAX_PARALLEL_AI_REQUESTS=5

# Путь к SQLite базе данных
DB_PATH=./data/jobs.db

# --- Telegram уведомления (опционально) ---
# Если заданы — агент будет присылать уведомления о вакансиях класса A
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Логирование ---
# Уровень: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
